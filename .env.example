## OpenAI-compatible LLM configuration (server-side)
#
# IMPORTANT:
# - Never commit your real key.
# - For local dev, copy this to `.env.local` and fill in values.
#
# OPENAI_API_KEY=sk-your_key_here
#
# Optional (defaults to OpenAI official endpoint if omitted by the SDK)
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Optional
# OPENAI_MODEL=gpt-4o-mini

## DeepSeek (OpenAI-compatible) example
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

